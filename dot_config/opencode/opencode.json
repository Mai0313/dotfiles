{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "enabled_providers": [
    "openai",
    "google",
    "anthropic",
    "deepseek",
    "copilot",
    "openrouter",
    "xai",
    "azure",
    "huggingface",
    "opencode"
  ],
  "provider": {
    "openai": {
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}",
        "headers": {
          "x-litellm-end-user-id": "opencode-cli"
        }
      }
    },
    "deepseek": {
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}",
        "headers": {
          "x-litellm-end-user-id": "opencode-cli"
        }
      }
    },
    "google": {
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}",
        "headers": {
          "x-litellm-end-user-id": "opencode-cli"
        }
      }
    }
  }
}